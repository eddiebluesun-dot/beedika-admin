{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/clientes",
      "regex": "^/clientes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/clientes(?:/)?$"
    },
    {
      "page": "/distribuidoras",
      "regex": "^/distribuidoras(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/distribuidoras(?:/)?$"
    },
    {
      "page": "/engenheiro",
      "regex": "^/engenheiro(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/engenheiro(?:/)?$"
    },
    {
      "page": "/financeiro",
      "regex": "^/financeiro(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/financeiro(?:/)?$"
    },
    {
      "page": "/leads",
      "regex": "^/leads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/leads(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/parceiros",
      "regex": "^/parceiros(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/parceiros(?:/)?$"
    },
    {
      "page": "/planos",
      "regex": "^/planos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/planos(?:/)?$"
    },
    {
      "page": "/relatorios",
      "regex": "^/relatorios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/relatorios(?:/)?$"
    },
    {
      "page": "/usuarios",
      "regex": "^/usuarios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/usuarios(?:/)?$"
    },
    {
      "page": "/whatsapp",
      "regex": "^/whatsapp(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/whatsapp(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}